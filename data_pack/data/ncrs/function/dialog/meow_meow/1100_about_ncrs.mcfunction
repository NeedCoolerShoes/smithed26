tellraw @s [{player: {name: "NeedCoolerShoes"}}," \"NeedCoolerShoes is a website for editing and sharing skins. It started as a restoration of a site called Miners Need Cool Shoes, but has since grown into its own community.\"\n\n",{player: {name: "NeedCoolerShoes"}}," \"It focuses on providing a streamlined, easy to use editor free of any ads or anti-features.\"\n\n",{player: {name: "NeedCoolerShoes"}}," \"As well, our editor integrates with our skin gallery, and encourages users to share their skins for others to remix.\"\n\n",{text:"Continue...",color: "blue",click_event:{action:"run_command",command:"/trigger ncrs.dialog set 1000"}}]