summon text_display -28.01 78.1 -223.7 {Tags:["ncrs.shop.decor"],text:[{text:"History\n",color:"aqua",bold:true},{text: "NeedCoolerShoes started life as a recreation of the old skin editor Miners Need Cool Shoes. The old site had been unmaintained for many years, and eventually, in January of 2023, went offline forever.\nUnfortunately, this meant that many skins from the old site were lost forever. Luckily, even if many skins could not be saved, the Internet Archive had a copy of the site, and the old editor itself could be restored. This task was taken on by Moxvallix, and over time the site grew and more and more functionality was added.\n\nEventually, Moxvallix and the Restoration Team started work on a full rewrite of the editor, modernising the codebase, and focusing on mobile and touch support.",color:"black",bold:false}],Rotation:[90,0],transformation:{left_rotation:[0f,0f,0f,1f],right_rotation:[0f,0f,0f,1f],translation:[0f,0f,0f],scale:[0.5f,0.5f,0.5f]},alignment:"left",background:0}
summon text_display -28.01 79 -221.0 {Tags:["ncrs.shop.decor"],text:[{text:"Features\n",color:"aqua",bold:true},{text: "NeedCoolerShoes is a feature rich editor. It aims to be simple enough for new skin makers, but still provide many powerful tools for more advanced skin makers.\n\nSome stand out features are as follows:\n- First class layer support\n- Non-destructive filters\n- Skin gallery integration\n- Slim model support\n- Transparency\n- Touch and mobile support",color:"black",bold:false}],Rotation:[90,0],transformation:{left_rotation:[0f,0f,0f,1f],right_rotation:[0f,0f,0f,1f],translation:[0f,0f,0f],scale:[0.5f,0.5f,0.5f]},alignment:"left",background:0}
summon text_display -28.01 78.75 -218.3 {Tags:["ncrs.shop.decor"],text:[{text: "",color:"black"},{text:"Mascot\n",color:"aqua",bold:true},"Little Meow Meow ",{player: {name: "NeedCoolerShoes"},color:"white"}," is the mascot of NeedCoolerShoes. They were designed by ", {text: "@doofus", color: "aqua"}, " in the mascot jam, and named by ", {text: "@kittykay27", color: "aqua"}, ". Little Meow Meow is non-binary, and goes by they/them.\n\nTry making a mask of their face, and join the Cult of the Meow Meow!\n\n",{text:"Credits\n",color:"aqua",bold:true}, "- Moxvallix: Site dev, booth dev.\n- Wulfian: Booth builder, site helper.\n- Pancake: Site designer, poster maker.\n- Maya: Site backend.\n- OwaHai: Booth mockup, site helper.\n- KittyKay: Skin restorationist."],Rotation:[90,0],transformation:{left_rotation:[0f,0f,0f,1f],right_rotation:[0f,0f,0f,1f],translation:[0f,0f,0f],scale:[0.5f,0.5f,0.5f]},alignment:"left",background:0}
